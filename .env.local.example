# Copy to .env.local and fill in. All are optional for local dev —
# the site degrades gracefully when any are missing (see DEPLOY.md).

# Concierge chat (Claude Haiku). Without it, chat uses the offline fallback.
ANTHROPIC_API_KEY=

# Live "Scooping Today" board admin passcode (defaults to LAGO2025 if unset).
ADMIN_PASSCODE=

# Lead capture → emailed to the owner via Resend.
OWNER_EMAIL=lagosicecream@yahoo.com
RESEND_API_KEY=
LEAD_FROM_EMAIL="Lago's Website <onboarding@resend.dev>"

# Durable shared state for the live board (Vercel → Storage → Upstash).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase — stores all form submissions + powers the /admin dashboard.
# Run supabase/schema.sql first. Service-role key is server-only (never public).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
